# ================================
# AUTH (Clerk)
# ================================

# Get from Clerk Dashboard → https://dashboard.clerk.com/
# Go to your project → API Keys → Backend API Keys
CLERK_SECRET_KEY=

# Your frontend app domain (for local dev keep as localhost)
DOMAIN=http://localhost:3000/


# ================================
# STORAGE (Tigris S3 - AWS Compatible)
# ================================

# 1. Create account at https://www.tigrisdata.com/
# 2. Create a Project
# 3. Go to Access Keys → Create Access Key
# 4. Grant ADMIN permissions (Full S3 access)
# 5. Copy Access Key ID & Secret
# 6. Create a bucket and use its name below

S3_BUCKET_NAME=

# From Tigris Access Keys
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Tigris S3 endpoint (example format below)
# Check your dashboard for the correct endpoint
AWS_ENDPOINT_URL_IAM=https://fly.storage.tigris.dev

# Region is usually:
AWS_REGION=auto


# ================================
# DATABASE (Supabase)
# ================================

# 1. Go to https://supabase.com/dashboard
# 2. Create a project
# 3. Go to Settings → API
# 4. Copy:
#    - Project URL
#    - Service Role Key (NOT anon key)

SUPABASE_API_URL=
SUPABASE_SECRET_KEY=
# SECRET KEY HERE IS THE SERVICE ROLE KEY (keep private)


# ================================
# SEARCH / SCRAPING
# ================================

# Get from https://tavily.com/
# Dashboard → API Keys
TAVILY_API_KEY=

# Get from https://www.scrapingbee.com/
# Dashboard → API Key(Paid)
#placeholder as its an alternative
SCRAPINGBEE_API_KEY=any_placeholder_as_of_now


# ================================
# CACHE (Redis)
# ================================

# Local Docker Redis default:
REDIS_URL=redis://redis:6379

# ================================
# AI (OpenAI)
# ================================

# Get from https://platform.openai.com/api-keys
# Create new secret key
OPENAI_API_KEY=